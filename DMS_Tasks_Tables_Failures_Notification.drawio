        </mxCell>
        <mxCell id="L_OjnDgUtOwJDbCJSkx4-17" value="&lt;b&gt;2. Search the CloudWatch Log Group for any table errors for each DMS Task retrieved in Step 1.&lt;/b&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="UEzPUAAOIrF-is8g5C7q-175" vertex="1">
