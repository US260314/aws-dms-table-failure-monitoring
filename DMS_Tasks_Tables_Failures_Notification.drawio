        </mxCell>
        <mxCell id="L_OjnDgUtOwJDbCJSkx4-18" value="&lt;b&gt;3.&amp;nbsp;If any table errors are detected in the CloudWatch Log Group, trigger the SNS topic to send an email notification with details of the table errors.&lt;/b&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="UEzPUAAOIrF-is8g5C7q-175" vertex="1">
