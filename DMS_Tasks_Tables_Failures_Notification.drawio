        <mxCell id="L_OjnDgUtOwJDbCJSkx4-16" value="&lt;b&gt;1. Retrieve information for only DMS Tasks involving Full Load and Ongoing Changes from AWS DMS.&lt;/b&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="UEzPUAAOIrF-is8g5C7q-175" vertex="1">
